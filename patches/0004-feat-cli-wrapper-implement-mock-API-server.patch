+	const check = async () => {
+		const latest = await fetchLatestRelease();
+		if (!latest) {
+			return; // Silently skip if we can't reach GitHub
+		}
+
+		if (isNewerVersion(currentVersion, latest.version)) {
+			console.log("");
+			console.log(`  ╔══════════════════════════════════════════════════════╗`);
+			console.log(`  ║  🆕 New version available: ${latest.version.padEnd(10)} (current: ${currentVersion.padEnd(8)}) ║`);
+			console.log(`  ║  https://github.com/superset-sh/superset/releases   ║`);
+			console.log(`  ╚══════════════════════════════════════════════════════╝`);
+			console.log("");
+		} else {
+			console.log(`Version: ${currentVersion} (up to date)`);
+		}
+	};
+
+	// Run immediately at startup
+	check().catch(() => {});
+
+	// And then poll every 4 hours to match the desktop app's toast cycle
+	const interval = setInterval(() => {
+		check().catch(() => {});
+	}, UPDATE_CHECK_INTERVAL_MS);
+	interval.unref();
+}

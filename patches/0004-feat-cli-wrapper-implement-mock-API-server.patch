+import { Hono } from "hono";
+
+export const versionRouter = new Hono();
+
+// GitHub releases manifest URL for Linux auto-updates.
+const RELEASES_MANIFEST_URL =
+	"https://github.com/superset-sh/superset/releases/latest/download/latest-linux.yml";
+
+// Cache the latest release info so we don't hammer GitHub on every request.
+let cachedRelease: {
+	version: string;
+	releaseDate: string;
+	files: { url: string; sha512: string; size: number }[];
+	fetchedAt: number;
+} | null = null;
+
+const CACHE_TTL_MS = 4 * 60 * 60 * 1000; // 4 hours, same as the desktop auto-updater interval
+
+/**
+ * Fetch the latest release manifest from GitHub releases.
+ * Parses the electron-builder `latest-linux.yml` format.
+ */
+async function fetchLatestRelease() {
+	if (cachedRelease && Date.now() - cachedRelease.fetchedAt < CACHE_TTL_MS) {
+		return cachedRelease;
+	}
+
+	try {
+		const response = await fetch(RELEASES_MANIFEST_URL, {
+			headers: { "User-Agent": "superset-dev-cli" },
+			redirect: "follow",
+			signal: AbortSignal.timeout(10_000),
+		});
+
+		if (!response.ok) {
+			console.warn(
+				`[version-check] Failed to fetch release manifest: HTTP ${response.status}`,
+			);
+			return cachedRelease; // Return stale cache if available
+		}
+
+		const text = await response.text();
+		
+		// Simple parsing since we don't have a YAML parser available.
+		// electron-builder manifests are very flat and consistent.
+		const versionMatch = text.match(/^version:\s*(.+)$/m);
+		const dateMatch = text.match(/^releaseDate:\s*['"]?([^'"\n]+)['"]?$/m);
+
+		if (!versionMatch) {
+			console.warn("[version-check] Release manifest missing version field");
+			return cachedRelease;
+		}
+
+		cachedRelease = {
+			version: versionMatch[1].trim(),
+			releaseDate: dateMatch ? dateMatch[1].trim() : new Date().toISOString(),
+			files: [], // Files list omitted for simple parser
+			fetchedAt: Date.now(),
+		};
+
+		return cachedRelease;
+	} catch (error) {
+		const msg = error instanceof Error ? error.message : String(error);
+		console.warn(`[version-check] Failed to check for updates: ${msg}`);
+		return cachedRelease; // Return stale cache on network error
+	}
+}
+
+// GET /api/version/check?current=1.12.5
+// Returns the latest available version and whether an update is available.
+versionRouter.get("/check", async (c) => {
+	const currentVersion = c.req.query("current") ?? "0.0.0";
+
+	const latest = await fetchLatestRelease();
+	if (!latest) {
+		return c.json({
+			updateAvailable: false,
+			currentVersion,
+			latestVersion: null,
+			error: "Unable to check for updates",
+		});
+	}
+
+	// Simple semver comparison (major.minor.patch)
+	const updateAvailable = isNewerVersion(currentVersion, latest.version);
+
+	return c.json({
+		updateAvailable,
+		currentVersion,
+		latestVersion: latest.version,
+		releaseDate: latest.releaseDate,
+		downloadUrl: `https://github.com/superset-sh/superset/releases/latest`,
+		files: latest.files,
+	});
+});
+
+// GET /api/version/latest
+// Returns just the latest version info (no comparison needed).
+versionRouter.get("/latest", async (c) => {
+	const latest = await fetchLatestRelease();
+	if (!latest) {
+		return c.json({ error: "Unable to fetch latest version" }, 503);
+	}
+
+	return c.json({
+		version: latest.version,
+		releaseDate: latest.releaseDate,
+		downloadUrl: `https://github.com/superset-sh/superset/releases/latest`,
+		files: latest.files,
+	});
+});
+
+/**
+ * Compare two semver strings. Returns true if `latest` is newer than `current`.
+ */
+function isNewerVersion(current: string, latest: string): boolean {
+	const parseVersion = (v: string) => {
+		const clean = v.replace(/^v/, "");
+		const [main, pre] = clean.split("-");
+		const parts = (main ?? "0.0.0").split(".").map(Number);
+		return { major: parts[0] ?? 0, minor: parts[1] ?? 0, patch: parts[2] ?? 0, pre: pre ?? "" };
+	};
+
+	const c = parseVersion(current);
+	const l = parseVersion(latest);
+
+	if (l.major !== c.major) return l.major > c.major;
+	if (l.minor !== c.minor) return l.minor > c.minor;
+	if (l.patch !== c.patch) return l.patch > c.patch;
+
+	// If latest has no pre-release but current does, latest is newer
+	if (c.pre && !l.pre) return true;
+	return false;
+}
